{
  "expo": {
    "name": "Sipelle",
    "slug": "sipelle",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sipelle",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "app.sipelle",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.sipelle",
      "allowBackup": false,
      "adaptiveIcon": {
        "backgroundColor": "#FBE7E6",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-blank.png",
          "backgroundColor": "#FBE7E6"
        }
      ],
      "expo-sqlite",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Sipelle uses your camera to photograph drink menus.",
          "microphonePermission": false,
          "photosPermission": false
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "42231e60-5e45-4185-b4e0-41da84ff3a7e"
      }
    },
    "owner": "duppyman3"
  }
}
